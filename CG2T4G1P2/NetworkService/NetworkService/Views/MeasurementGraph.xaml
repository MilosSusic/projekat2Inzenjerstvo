<UserControl x:Class="NetworkService.Views.MeasurementGraph"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             xmlns:viewModel="clr-namespace:NetworkService.ViewModel"
             xmlns:views="clr-namespace:NetworkService.Views"  
             xmlns:converters="clr-namespace:NetworkService.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" x:Name="CanvasGraph">
    <UserControl.Resources>
        <converters:ValueToCenterConverter x:Key="ValueToCenterConverter"/>
        <converters:ValueToColorConverter x:Key="ValueToColorConverter"/>
    </UserControl.Resources>

    <Grid Background="#FFF5F5F5" Margin="0,30" Height="500">
        <Grid Margin="0,10,83,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="0.7*"/>
            </Grid.ColumnDefinitions>

            <!-- Graph label -->
            <TextBlock Grid.Column="1" HorizontalAlignment="Center" Text="Graph"  
                       FontSize="36" Margin="0 25 0 0" Grid.RowSpan="2" VerticalAlignment="Top"
                       Foreground="#FF1E40AF" FontWeight="Bold"/>

            <!-- Horizontal labels under graph -->
            <StackPanel Margin="31,510,31,0" Orientation="Horizontal" VerticalAlignment="Top" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Height="246" Grid.RowSpan="2">
                <TextBlock HorizontalAlignment="Left" Text="1st" Foreground="#FF1E40AF" FontWeight="SemiBold"/>
                <TextBlock Text="2nd"  Margin="50 0 0 0" Foreground="#FF1E40AF" FontWeight="SemiBold"/>
                <TextBlock Text="3rd"  Margin="50 0 0 0" Foreground="#FF1E40AF" FontWeight="SemiBold"/>
                <TextBlock Text="4th"  Margin="50 0 0 0" Foreground="#FF1E40AF" FontWeight="SemiBold"/>
                <TextBlock Text="5th" Margin="50 0 0 0" Foreground="#FF1E40AF" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Canvas with graph -->
            <Canvas x:Name="GraphCanvas" Grid.Column="1" Grid.Row="1" Width="350" Height="270" Background="#FFF0F0F0" HorizontalAlignment="Left">
                <!-- Background lines -->
                <Line X1="10"  Y1="10" X2="10"  Y2="260" Stroke="#FFCBD5E1" StrokeThickness="2"/>
                <Line X1="80"  Y1="10" X2="80"  Y2="260" Stroke="#FFCBD5E1" StrokeThickness="2"/>
                <Line X1="150" Y1="10" X2="150" Y2="260" Stroke="#FFCBD5E1" StrokeThickness="2"/>
                <Line X1="220" Y1="10" X2="220" Y2="260" Stroke="#FFCBD5E1" StrokeThickness="2"/>
                <Line X1="290" Y1="10" X2="290" Y2="260" Stroke="#FFCBD5E1" StrokeThickness="2"/>
                <Line X1="340" Y1="10" X2="340" Y2="260" Stroke="#FFCBD5E1" StrokeThickness="2"/>

                

                <!-- Graph lines -->
                <Line Stroke="#FF1E40AF" StrokeThickness="2"
                      X1="40"
                      Y1="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FirstDot, Converter={StaticResource ValueToCenterConverter}, ConverterParameter=17}"
                      X2="107"
                      Y2="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=SecondDot, Converter={StaticResource ValueToCenterConverter}, ConverterParameter=17}"/>
                <Line Stroke="#FF1E40AF" StrokeThickness="2"
                      X1="107"
                      Y1="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=SecondDot, Converter={StaticResource ValueToCenterConverter}, ConverterParameter=17}"
                      X2="177"
                      Y2="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=ThirdDot, Converter={StaticResource ValueToCenterConverter}, ConverterParameter=17}"/>
                <Line Stroke="#FF1E40AF" StrokeThickness="2"
                      X1="177"
                      Y1="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=ThirdDot, Converter={StaticResource ValueToCenterConverter}, ConverterParameter=17}"
                      X2="244"
                      Y2="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FourthDot, Converter={StaticResource ValueToCenterConverter}, ConverterParameter=17}"/>
                <Line Stroke="#FF1E40AF" StrokeThickness="2"
                      X1="244"
                      Y1="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FourthDot, Converter={StaticResource ValueToCenterConverter}, ConverterParameter=17}"
                      X2="320"
                      Y2="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FifthDot, Converter={StaticResource ValueToCenterConverter}, ConverterParameter=17}"/>

                <!-- Graph ellipses -->
                <Ellipse Stroke="#FF1E40AF" StrokeThickness="2" Height="30" Width="30"
                         Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FirstDot}"
                         Canvas.Left="25"
                         Fill="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FirstValue, Converter={StaticResource ValueToColorConverter}}"/>
                <Ellipse Stroke="#FF1E40AF" StrokeThickness="2" Height="30" Width="30"
                         Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=SecondDot}"
                         Canvas.Left="92"
                         Fill="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=SecondValue, Converter={StaticResource ValueToColorConverter}}"/>
                <Ellipse Stroke="#FF1E40AF" StrokeThickness="2" Height="30" Width="30"
                         Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=ThirdDot}"
                         Canvas.Left="162"
                         Fill="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=ThirdValue, Converter={StaticResource ValueToColorConverter}}"/>
                <Ellipse Stroke="#FF1E40AF" StrokeThickness="2" Height="30" Width="30"
                         Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FourthDot}"
                         Canvas.Left="229"
                         Fill="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FourthValue, Converter={StaticResource ValueToColorConverter}}"/>
                <Ellipse Stroke="#FF1E40AF" StrokeThickness="2" Height="30" Width="30"
                         Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FifthDot}"
                         Canvas.Left="295"
                         Fill="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FifthValue, Converter={StaticResource ValueToColorConverter}}"/>

                <!-- Values inside ellipses -->
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FirstValue}"  
                           FontSize="11" FontWeight="Bold" Canvas.Left="35"  Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FirstDot}"/>
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=SecondValue}" 
                           FontSize="11" FontWeight="Bold" Canvas.Left="103" Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=SecondDot}"/>
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=ThirdValue}"  
                           FontSize="11" FontWeight="Bold" Canvas.Left="172" Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=ThirdDot}"/>
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FourthValue}" 
                           FontSize="11" FontWeight="Bold" Canvas.Left="240" Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FourthDot}"/>
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FifthValue}"  
                           FontSize="11" FontWeight="Bold" Canvas.Left="306" Canvas.Top="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FifthDot}"/>

                <!-- Time labels under graph -->
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FirstTime}"  FontSize="11" FontWeight="Bold" Canvas.Left="35"  Canvas.Top="275" Foreground="#FF1E40AF"/>
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=SecondTime}" FontSize="11" FontWeight="Bold" Canvas.Left="103" Canvas.Top="275" Foreground="#FF1E40AF"/>
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=ThirdTime}"  FontSize="11" FontWeight="Bold" Canvas.Left="172" Canvas.Top="275" Foreground="#FF1E40AF"/>
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FourthTime}" FontSize="11" FontWeight="Bold" Canvas.Left="240" Canvas.Top="275" Foreground="#FF1E40AF"/>
                <TextBlock Text="{Binding Source={x:Static viewModel:MeasurementGraphModel.ElementHeights}, Path=FifthTime}"  FontSize="11" FontWeight="Bold" Canvas.Left="306" Canvas.Top="275" Foreground="#FF1E40AF"/>
            </Canvas>
        </Grid>

        <!-- Select Entities ComboBox -->
        <Grid>
            <ComboBox HorizontalAlignment="Left" Margin="650,86,0,0" VerticalAlignment="Top" Width="120">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="DropDownOpened">
                        <i:InvokeCommandAction Command="{Binding OpenedComboBoxCommand}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Content="Select Entities" 
                                          ClickMode="Press"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup x:Name="Popup" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True" 
                                   Focusable="False">
                                <Grid Background="White">
                                    <ScrollViewer>
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding CheckBoxProduction}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding Naziv}"
                                                                  IsChecked="{Binding IsChecked}"
                                                                  Command="{Binding DataContext.CheckboxCommand, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                                  CommandParameter="{Binding}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
            </ComboBox>
        </Grid>
    </Grid>
</UserControl>