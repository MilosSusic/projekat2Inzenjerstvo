<UserControl x:Class="NetworkService.Views.NetworkDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
            xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:viewModel ="clr-namespace:NetworkService.ViewModel"
             mc:Ignorable="d" 
             Height="500" Width="1000">

    <UserControl.Resources>
        <!-- Dugme stil (isti kao na prvoj stranici) -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Glavni grid sa marginom da prati izgled prve stranice -->
    <Grid x:Name="MainGrid" Background="White" Margin="15">
        <Grid x:Name="GridCanvases" Margin="5" HorizontalAlignment="Left" Width="600" Height="450">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CANVAS 1 -->
            <Canvas x:Name="canvas1" Height="120" Width="140" Grid.Column="0" Grid.Row="0" 
                    Background="#FFF1F5F9" AllowDrop="True" Margin="10">
                <Image Source="{Binding Slika1}" Width="140" Height="70"/>
                <TextBlock Width="120" Canvas.Left="0" Canvas.Top="65" Height="35" 
                           TextWrapping="Wrap" TextAlignment="Center" 
                           Text="{Binding Tekst1}" FontSize="14" FontWeight="Bold"/>
                <Button Width="120" Content="Delete" Canvas.Top="95" Margin="10 25 0 0"
                        Command="{Binding ButtonFunkcija}" CommandParameter="{Binding ElementName=canvas1}"/>
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Drop">
                        <i:InvokeCommandAction Command="{Binding DropFunkcija}" CommandParameter="{Binding ElementName=canvas1}" />
                    </i:EventTrigger>
                    <i:EventTrigger EventName="dragOver">
                        <i:InvokeCommandAction Command="{Binding DragOverFunkcija}" CommandParameter="{Binding ElementName=canvas1}" />
                    </i:EventTrigger>
                    <i:EventTrigger EventName="MouseLeftButtonDown">
                        <i:InvokeCommandAction Command="{Binding UzmiCanvas}" CommandParameter="{Binding ElementName=canvas1}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Canvas>

