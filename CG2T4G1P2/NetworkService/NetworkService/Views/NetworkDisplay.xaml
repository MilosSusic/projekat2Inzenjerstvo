        <!-- ListView desno, sa istim borderom kao u prvoj stranici -->
        <Border BorderBrush="#FFCBD5E1" BorderThickness="1" CornerRadius="5" Margin="630,0,0,0">
            <ListView Width="300" Height="450" x:Name="pregledListe" 
                      ItemsSource="{Binding listaStavki}" 
                      SelectedItem="{Binding selektovanaStavka}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <i:InvokeCommandAction Command="{Binding Promena}" CommandParameter="{Binding ElementName=pregledListe}" />
                    </i:EventTrigger>
                    <i:EventTrigger EventName="MouseLeftButtonUp">
                        <i:InvokeCommandAction Command="{Binding PustenMis}" />
